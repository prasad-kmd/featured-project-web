# Application Configuration
SITE_URL=http://localhost:3000/

# Telegram Notification (Optional)
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Entertainment APIs (Movies & TV Shows)
TMDB_API_KEY=your_tmdb_api_key_here
TMDB_API_READ_ACCESS_TOKEN=your_tmdb_read_access_token_here
OMDB_API=your_omdb_api_key_here
YTS_API=https://movies-api.accel.li/api/v2/

# Notion CMS Integration
# Find these IDs in your Notion workspace URLs
NOTION_ROOT_PAGE_ID=your_notion_root_page_id
NOTION_BLOG_ID=your_notion_blog_database_id
NOTION_ARTICLES_ID=your_notion_articles_database_id
NOTION_PROJECTS_ID=your_notion_projects_database_id
NOTION_TUTORIALS_ID=your_notion_tutorials_database_id
NOTION_WIKI_ID=your_notion_wiki_database_id
NOTION_AUTHORS_ID=your_notion_authors_database_id
NOTION_AUTH_TOKEN=your_notion_integration_token_here

# General Next.js Configuration
NEXT_TELEMETRY_DISABLED=1

# Social Media & Public Profile Links
NEXT_PUBLIC_GITHUB_USERNAME=your_github_username
NEXT_PUBLIC_GITHUB_URL=https://github.com/your_github_username
NEXT_PUBLIC_TWITTER_URL=https://twitter.com/your_twitter_handle
NEXT_PUBLIC_LINKEDIN_URL=https://linkedin.com/in/your_profile
NEXT_PUBLIC_EMAIL=contact@yourdomain.com
NEXT_PUBLIC_GITHUB_SPONSORS_URL=https://github.com/sponsors/your_github_username

# Web Push Notifications
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key_here
